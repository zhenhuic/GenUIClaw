{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "composite": true,
    "outDir": "out/renderer",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["./renderer/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["renderer/**/*", "shared/**/*"]
}
